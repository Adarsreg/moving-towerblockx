{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "echo 'static site - no build; wasm is prebuilt in /pkg'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/pkg/(.*)\.wasm",
      "headers": [{ "key": "Content-Type", "value": "application/wasm" }]
    }
  ]
}
